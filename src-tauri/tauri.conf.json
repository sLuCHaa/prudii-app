{
  "$schema": "https://raw.githubusercontent.com/nicegui-group/tauri-v2-schema/main/tauri.conf.json",
  "productName": "Prudii Mail",
  "version": "1.1.1",
  "identifier": "com.prudii.mail",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'sha256-lo44IaNMj8n102MDbFbLK+h3Td+693IksT6jAzsGPFI='; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: http://asset.localhost https://asset.localhost https: http:; font-src 'self' data:; connect-src ipc: http://ipc.localhost; frame-src 'self' asset: blob: https://asset.localhost",
      "dangerousDisableAssetCspModification": [
        "style-src"
      ],
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/attachments/**",
          "$APPDATA/attachments/*"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "Prudii",
    "shortDescription": "Privacy-first email client",
    "longDescription": "Prudii Mail is a privacy-first desktop email client with IMAP sync, full-text search, and end-to-end encryption.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "headerImage": "nsis/header.bmp",
        "sidebarImage": "nsis/sidebar.bmp",
        "installerIcon": "icons/icon.ico",
        "displayLanguageSelector": false,
        "installMode": "currentUser"
      }
    }
  }
}
